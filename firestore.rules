rules_version = '2';

// BuddyRead Firestore security rules.
// Tight by default — readers touch only their own data, and a friendship can
// only exist with both parties' consent. reads/{readId} rules arrive in M4.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }
    // Deterministic pair id — uids sorted so direction doesn't matter. Must
    // match pairId() in src/lib/friends.ts.
    function pairId(a, b) {
      return a < b ? a + '__' + b : b + '__' + a;
    }

    // A reader's own profile. Only the owner reads or writes it; buddies never
    // need to read it directly (display data is denormalized onto requests).
    match /users/{uid} {
      allow read: if isSelf(uid);
      allow create: if isSelf(uid);
      allow update: if isSelf(uid);
      allow delete: if false;

      // A reader's private activity feed. The owner reads (and may dismiss) it;
      // anyone signed in may append, but only as themselves (actorUid == them),
      // so an event is always attributable. Immutable once written.
      match /activity/{eventId} {
        allow read: if isSelf(uid);
        allow create: if signedIn()
                      && request.resource.data.actorUid == request.auth.uid;
        allow delete: if isSelf(uid);
      }
    }

    // invite code -> owner lookup (uid + denormalized name/photo). Readable by
    // any signed-in reader (you only learn it if a code is shared with you);
    // only the owner may create or refresh it, and the uid can never change.
    match /inviteCodes/{code} {
      allow read: if signedIn();
      allow create: if signedIn()
                    && request.resource.data.uid == request.auth.uid;
      allow update: if signedIn()
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    // The single source of truth for a relationship, keyed by sorted pair id.
    // Statuses are pending | accepted; declining/cancelling/unfriending all
    // just delete the doc, so re-requesting is a clean create.
    match /friendRequests/{reqId} {
      allow read: if signedIn()
                  && request.auth.uid in resource.data.participants;

      // Only the sender creates it, only as pending, only at the correct id,
      // and only with both parties (and not to themselves).
      allow create: if signedIn()
                    && request.auth.uid == request.resource.data.fromUid
                    && request.resource.data.fromUid != request.resource.data.toUid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.participants
                       == [request.resource.data.fromUid, request.resource.data.toUid]
                    && reqId == pairId(request.resource.data.fromUid,
                                       request.resource.data.toUid);

      // Only the recipient accepts; parties can't change, only pending->accepted.
      allow update: if signedIn()
                    && request.auth.uid == resource.data.toUid
                    && resource.data.status == 'pending'
                    && request.resource.data.status == 'accepted'
                    && request.resource.data.fromUid == resource.data.fromUid
                    && request.resource.data.toUid == resource.data.toUid
                    && request.resource.data.participants == resource.data.participants;

      // Either party can delete (decline / cancel / unfriend).
      allow delete: if signedIn()
                    && request.auth.uid in resource.data.participants;
    }

    // A buddy read between two friends. Auto-id (a pair can have many reads).
    // pending = a request; active = accepted. Decline/cancel/leave = delete.
    match /reads/{readId} {
      function friendDoc() {
        return get(/databases/$(database)/documents/friendRequests/$(pairId(
          request.resource.data.fromUid, request.resource.data.toUid)));
      }

      allow read: if signedIn()
                  && request.auth.uid in resource.data.participants;

      // Only the sender creates it, only as pending, addressed to an actual
      // friend (an accepted relationship must exist), never to oneself.
      allow create: if signedIn()
                    && request.auth.uid == request.resource.data.fromUid
                    && request.resource.data.fromUid != request.resource.data.toUid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.participants
                       == [request.resource.data.fromUid, request.resource.data.toUid]
                    && request.resource.data.progress == {}
                    && friendDoc().data.status == 'accepted';

      // Updates keep the parties and the book fixed. Two shapes are allowed:
      //  (a) the recipient accepts (pending -> active, nothing else changes), or
      //  (b) a participant edits only their OWN entry in `progress` on an
      //      active read (setting up their edition, or logging pages).
      allow update: if signedIn()
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.fromUid == resource.data.fromUid
        && request.resource.data.toUid == resource.data.toUid
        && request.resource.data.book == resource.data.book
        && (
          ( request.auth.uid == resource.data.toUid
            && resource.data.status == 'pending'
            && request.resource.data.status == 'active'
            && request.resource.data.progress == resource.data.progress
          )
          ||
          ( resource.data.status == 'active'
            && request.resource.data.status == 'active'
            && request.resource.data.progress.diff(resource.data.progress)
                 .affectedKeys().hasOnly([request.auth.uid])
          )
        );

      // Either party can delete (decline / cancel / leave the read).
      allow delete: if signedIn()
                    && request.auth.uid in resource.data.participants;
    }
  }
}
