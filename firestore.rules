rules_version = '2';

// BuddyRead Firestore security rules.
// Tight by default — readers touch only their own data, and a friendship can
// only exist with both parties' consent. reads/{readId} rules arrive in M4.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }
    // Deterministic pair id — uids sorted so direction doesn't matter. Must
    // match pairId() in src/lib/friends.ts.
    function pairId(a, b) {
      return a < b ? a + '__' + b : b + '__' + a;
    }

    // A reader's own profile. Only the owner reads or writes it; buddies never
    // need to read it directly (display data is denormalized onto requests).
    match /users/{uid} {
      allow read: if isSelf(uid);
      allow create: if isSelf(uid);
      allow update: if isSelf(uid);
      allow delete: if false;
    }

    // invite code -> owner lookup (uid + denormalized name/photo). Readable by
    // any signed-in reader (you only learn it if a code is shared with you);
    // only the owner may create or refresh it, and the uid can never change.
    match /inviteCodes/{code} {
      allow read: if signedIn();
      allow create: if signedIn()
                    && request.resource.data.uid == request.auth.uid;
      allow update: if signedIn()
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    // The single source of truth for a relationship, keyed by sorted pair id.
    // Statuses are pending | accepted; declining/cancelling/unfriending all
    // just delete the doc, so re-requesting is a clean create.
    match /friendRequests/{reqId} {
      allow read: if signedIn()
                  && request.auth.uid in resource.data.participants;

      // Only the sender creates it, only as pending, only at the correct id,
      // and only with both parties (and not to themselves).
      allow create: if signedIn()
                    && request.auth.uid == request.resource.data.fromUid
                    && request.resource.data.fromUid != request.resource.data.toUid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.participants
                       == [request.resource.data.fromUid, request.resource.data.toUid]
                    && reqId == pairId(request.resource.data.fromUid,
                                       request.resource.data.toUid);

      // Only the recipient accepts; parties can't change, only pending->accepted.
      allow update: if signedIn()
                    && request.auth.uid == resource.data.toUid
                    && resource.data.status == 'pending'
                    && request.resource.data.status == 'accepted'
                    && request.resource.data.fromUid == resource.data.fromUid
                    && request.resource.data.toUid == resource.data.toUid
                    && request.resource.data.participants == resource.data.participants;

      // Either party can delete (decline / cancel / unfriend).
      allow delete: if signedIn()
                    && request.auth.uid in resource.data.participants;
    }
  }
}
