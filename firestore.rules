rules_version = '2';

// BuddyRead Firestore security rules.
// Tight by default — readers touch only their own data. Friend-visibility and
// reads/{readId} rules are added in later milestones (M2, M4).
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // A reader's own profile. For M1, only the owner can read or write it;
    // M2 will widen reads to a reader's friends' minimal public fields.
    match /users/{uid} {
      allow read: if isSelf(uid);
      allow create: if isSelf(uid);
      allow update: if isSelf(uid);
      allow delete: if false;
    }

    // invite code -> uid lookup, used to claim a unique code (and, in M2, to
    // resolve a code to a user without listing the whole users collection).
    match /inviteCodes/{code} {
      allow read: if signedIn();
      allow create: if signedIn()
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false; // codes are immutable in v0
    }
  }
}
